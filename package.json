{
  "name": "runcast-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun dev:vite\"",
    "dev:cached": "concurrently \"bun run dev:server\" \"bun dev:vite --mode cached\"",
    "dev:server": "bun run dev-server.js",
    "dev:vite": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "docker": "docker-compose up --build"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.34.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@netlify/functions": "^5.1.5",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "axios": "^1.14.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tanstack/eslint-plugin-query": "^5.96.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2"
  }
}
